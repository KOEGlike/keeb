---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="KEEB — Build Your Own Mechanical Keyboard | Hack Club Kit">
  <Nav />
  <main>
    <Hero />

    <!-- How It Works -->
    <section class="how-it-works">
      <div class="how-it-works__inner">
        <h2 class="section-title">HOW IT WORKS</h2>
        <div class="steps">
          <div class="step">
            <div class="step__number">01</div>
            <div class="step__icon">
              <svg width="48" height="48" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="8" y="6" width="32" height="36" />
                <line x1="14" y1="14" x2="34" y2="14" />
                <line x1="14" y1="20" x2="34" y2="20" />
                <line x1="14" y1="26" x2="28" y2="26" />
                <line x1="14" y1="32" x2="22" y2="32" />
              </svg>
            </div>
            <h3 class="step__title">FOLLOW THE GUIDE</h3>
            <p class="step__desc">Read through the docs. Learn about switches, PCBs, keycaps, and how it all fits together.</p>
          </div>

          <div class="step__connector">
            <svg width="48" height="24" viewBox="0 0 48 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="0" y1="12" x2="40" y2="12" />
              <polyline points="36,6 42,12 36,18" />
            </svg>
          </div>

          <div class="step">
            <div class="step__number">02</div>
            <div class="step__icon">
              <svg width="48" height="48" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="6" y="16" width="36" height="20" />
                <rect x="10" y="20" width="6" height="5" />
                <rect x="18" y="20" width="6" height="5" />
                <rect x="26" y="20" width="6" height="5" />
                <rect x="34" y="20" width="6" height="5" />
                <rect x="12" y="28" width="24" height="4" />
              </svg>
            </div>
            <h3 class="step__title">WE SHIP THE PARTS</h3>
            <p class="step__desc">Once you're ready, we send you everything you need — PCB, switches, keycaps, the whole kit.</p>
          </div>

          <div class="step__connector">
            <svg width="48" height="24" viewBox="0 0 48 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="0" y1="12" x2="40" y2="12" />
              <polyline points="36,6 42,12 36,18" />
            </svg>
          </div>

          <div class="step">
            <div class="step__number">03</div>
            <div class="step__icon">
              <svg width="48" height="48" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M24 6 L6 18 L6 38 L24 42 L42 38 L42 18 Z" />
                <polyline points="18,22 24,30 36,16" />
              </svg>
            </div>
            <h3 class="step__title">BUILD YOUR BOARD</h3>
            <p class="step__desc">Solder, assemble, flash your firmware, and you've got a custom mechanical keyboard.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Banner -->
    <section class="cta-banner bg-grid-dense">
      <div class="cta-banner__inner">
        <h2 class="cta-banner__title">READY TO GET STARTED?</h2>
        <p class="cta-banner__text">Check the docs, join the community, and start your build.</p>
        <div class="cta-banner__buttons">
          <a href="/docs" class="btn btn--primary">READ THE DOCS</a>
          <a href="https://github.com" target="_blank" rel="noopener noreferrer" class="btn btn--outline">VIEW ON GITHUB</a>
        </div>
      </div>
    </section>
  </main>
  <Footer />

  <!-- Easter egg overlay -->
  <div id="easter-egg-overlay" class="egg-overlay" aria-hidden="true">
    <div class="egg-overlay__scanlines"></div>
    <div class="egg-overlay__content">
      <pre class="egg-overlay__ascii">
 ██╗  ██╗███████╗███████╗██████╗
 ██║ ██╔╝██╔════╝██╔════╝██╔══██╗
 █████╔╝ █████╗  █████╗  ██████╔╝
 ██╔═██╗ ██╔══╝  ██╔══╝  ██╔══██╗
 ██║  ██╗███████╗███████╗██████╔╝
 ╚═╝  ╚═╝╚══════╝╚══════╝╚═════╝
      </pre>
      <p class="egg-overlay__msg">// ACCESS GRANTED</p>
      <p class="egg-overlay__sub">you found the secret. now go build something.</p>
    </div>
  </div>
</BaseLayout>

<script>
  const SEQUENCE = ['K', 'E', 'E', 'B'];
  let buffer: string[] = [];
  let eggActive = false;

  function triggerEasterEgg() {
    if (eggActive) return;
    eggActive = true;

    // 1. Glitch the page
    document.body.classList.add('egg-glitch');

    // 2. Wave-light every key on the keyboard visual
    const keys = document.querySelectorAll('.key');
    const keyboard = document.querySelector('.keyboard-case');
    if (keyboard) {
      const rect = keyboard.getBoundingClientRect();
      const centerX = rect.left + rect.width / 2;
      const centerY = rect.top + rect.height / 2;

      keys.forEach((key) => {
        const kr = key.getBoundingClientRect();
        const kx = kr.left + kr.width / 2;
        const ky = kr.top + kr.height / 2;
        const dist = Math.sqrt((kx - centerX) ** 2 + (ky - centerY) ** 2);
        const delay = dist * 1.8;

        setTimeout(() => {
          key.classList.add('key--wave');
          setTimeout(() => {
            key.classList.remove('key--wave');
            key.classList.add('key--lit');
          }, 400);
        }, delay);
      });
    }

    // 3. Show overlay after keys finish
    setTimeout(() => {
      const overlay = document.getElementById('easter-egg-overlay');
      if (overlay) {
        overlay.classList.add('egg-overlay--active');
      }
    }, 800);

    // 4. Dismiss on click or key
    const dismiss = () => {
      const overlay = document.getElementById('easter-egg-overlay');
      if (overlay) overlay.classList.remove('egg-overlay--active');
      document.body.classList.remove('egg-glitch');
      keys.forEach((key) => key.classList.remove('key--lit', 'key--wave'));
      eggActive = false;
      buffer = [];
      document.removeEventListener('click', dismiss);
      document.removeEventListener('keydown', dismiss);
    };

    setTimeout(() => {
      document.addEventListener('click', dismiss, { once: true });
      document.addEventListener('keydown', dismiss, { once: true });
    }, 1200);
  }

  // Listen for clicks on the CSS keyboard keys
  document.querySelectorAll('.key[data-key]').forEach((keyEl) => {
    keyEl.addEventListener('click', () => {
      if (eggActive) return;
      const label = (keyEl as HTMLElement).dataset.key?.toUpperCase() ?? '';
      if (!label) return;

      // Visual press feedback
      keyEl.classList.add('key--pressed');
      setTimeout(() => keyEl.classList.remove('key--pressed'), 150);

      buffer.push(label);
      if (buffer.length > SEQUENCE.length) buffer.shift();
      if (buffer.length === SEQUENCE.length && buffer.every((k, i) => k === SEQUENCE[i])) {
        triggerEasterEgg();
      }
    });
  });

  // Also keep physical keyboard listener
  document.addEventListener('keydown', (e) => {
    if (eggActive) return;
    const key = e.key.toUpperCase();
    if (key.length === 1 && /[A-Z]/.test(key)) {
      // Highlight the matching visual key
      const visualKey = document.querySelector(`.key[data-key="${key}"]`);
      if (visualKey) {
        visualKey.classList.add('key--pressed');
        setTimeout(() => visualKey.classList.remove('key--pressed'), 150);
      }

      buffer.push(key);
      if (buffer.length > SEQUENCE.length) buffer.shift();
      if (buffer.length === SEQUENCE.length && buffer.every((k, i) => k === SEQUENCE[i])) {
        triggerEasterEgg();
      }
    }
  });
</script>

<style>
  /* --- How It Works --- */
  .how-it-works {
    padding: 5rem 1.5rem;
    background: var(--purple-deep);
    position: relative;
    border-top: 3px solid var(--purple-royal);
    border-bottom: 3px solid var(--purple-royal);
  }

  /* Dot texture on the section */
  .how-it-works::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: radial-gradient(rgba(255, 255, 255, 0.08) 1px, transparent 1px);
    background-size: 16px 16px;
    pointer-events: none;
  }

  .how-it-works__inner {
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .section-title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    text-align: center;
    margin-bottom: 3.5rem;
    letter-spacing: 0.1em;
    position: relative;
  }

  .section-title::after {
    content: '';
    display: block;
    width: 60px;
    height: 4px;
    background: var(--purple-royal);
    margin: 0.75rem auto 0;
  }

  .steps {
    display: flex;
    align-items: flex-start;
    justify-content: center;
    gap: 1rem;
  }

  .step {
    flex: 1;
    max-width: 280px;
    text-align: center;
    padding: 2rem 1.5rem;
    border: 2px solid rgba(120, 81, 169, 0.3);
    background: rgba(10, 10, 10, 0.4);
    position: relative;
  }

  .step__number {
    font-family: var(--font-display);
    font-size: 3rem;
    color: rgba(120, 81, 169, 0.2);
    position: absolute;
    top: 0.5rem;
    right: 0.75rem;
    line-height: 1;
  }

  .step__icon {
    color: var(--purple-royal);
    margin-bottom: 1rem;
  }

  .step__title {
    font-size: 1.3rem;
    margin-bottom: 0.75rem;
    letter-spacing: 0.08em;
  }

  .step__desc {
    font-size: 0.8rem;
    color: var(--text-muted);
    line-height: 1.6;
  }

  .step__connector {
    color: var(--purple-royal);
    padding-top: 4rem;
    flex-shrink: 0;
  }

  @media (max-width: 768px) {
    .steps {
      flex-direction: column;
      align-items: center;
    }

    .step__connector {
      transform: rotate(90deg);
      padding-top: 0;
    }

    .step {
      max-width: 100%;
    }
  }

  /* --- CTA Banner --- */
  .cta-banner {
    padding: 5rem 1.5rem;
    text-align: center;
    border-bottom: 3px solid var(--purple-deep);
    position: relative;
  }

  /* Diagonal line texture */
  .cta-banner::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      repeating-linear-gradient(
        135deg,
        transparent,
        transparent 20px,
        rgba(75, 0, 110, 0.08) 20px,
        rgba(75, 0, 110, 0.08) 21px
      );
    pointer-events: none;
  }

  .cta-banner__inner {
    max-width: 600px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .cta-banner__title {
    font-size: clamp(1.8rem, 4vw, 3rem);
    margin-bottom: 1rem;
    letter-spacing: 0.05em;
  }

  .cta-banner__text {
    color: var(--text-muted);
    margin-bottom: 2rem;
    font-size: 0.9rem;
  }

  .cta-banner__buttons {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* Inline button styles for the CTA section */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    font-family: var(--font-display);
    font-size: 1.15rem;
    letter-spacing: 0.08em;
    text-decoration: none;
    cursor: pointer;
    transition: transform 0.1s, box-shadow 0.1s;
    border: 2px solid var(--purple-royal);
  }

  .btn--primary {
    background: var(--purple-royal);
    color: var(--white);
    box-shadow: var(--shadow-hard);
  }

  .btn--primary:hover {
    color: var(--white);
    transform: translate(2px, 2px);
    box-shadow: var(--shadow-hard-sm);
  }

  .btn--outline {
    background: transparent;
    color: var(--purple-royal);
    box-shadow: var(--shadow-hard);
  }

  .btn--outline:hover {
    color: var(--purple-light);
    transform: translate(2px, 2px);
    box-shadow: var(--shadow-hard-sm);
  }


</style>

<style is:global>
  /* Easter egg — must be global since classes are added by JS */
  .egg-glitch {
    animation: page-glitch 0.3s steps(4) 2;
  }

  @keyframes page-glitch {
    0% { transform: translate(0); }
    20% { transform: translate(-3px, 2px); }
    40% { transform: translate(3px, -1px); }
    60% { transform: translate(-1px, -3px); }
    80% { transform: translate(2px, 1px); }
    100% { transform: translate(0); }
  }

  .egg-overlay {
    position: fixed;
    inset: 0;
    z-index: 10000;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.3s;
  }

  .egg-overlay--active {
    opacity: 1;
    pointer-events: auto;
  }

  .egg-overlay__scanlines {
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0, 0, 0, 0.15) 2px,
      rgba(0, 0, 0, 0.15) 4px
    );
    pointer-events: none;
  }

  .egg-overlay__content {
    text-align: center;
    z-index: 1;
    background: rgba(10, 10, 10, 0.92);
    border: 3px solid var(--purple-royal);
    padding: 3rem 4rem;
    box-shadow: 8px 8px 0 var(--purple-deep), 0 0 120px rgba(75, 0, 110, 0.4);
    animation: egg-slide-in 0.3s ease-out;
  }

  @keyframes egg-slide-in {
    from { transform: translateY(20px) scale(0.95); opacity: 0; }
    to { transform: translateY(0) scale(1); opacity: 1; }
  }

  .egg-overlay__ascii {
    font-family: var(--font-mono);
    font-size: clamp(0.35rem, 1.2vw, 0.7rem);
    color: var(--purple-royal);
    line-height: 1.15;
    margin-bottom: 1.5rem;
    white-space: pre;
  }

  .egg-overlay__msg {
    font-family: var(--font-mono);
    font-size: 1rem;
    color: #00ff41;
    letter-spacing: 0.15em;
    margin-bottom: 0.5rem;
    animation: blink-cursor 1s step-end infinite;
  }

  @keyframes blink-cursor {
    50% { opacity: 0.5; }
  }

  .egg-overlay__sub {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  @media (max-width: 480px) {
    .egg-overlay__content {
      padding: 2rem 1.5rem;
    }

    .egg-overlay__ascii {
      font-size: 0.3rem;
    }
  }
</style>
