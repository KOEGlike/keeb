---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="KEEB ‚ÄĒ Build Your Own Mechanical Keyboard | Hack Club Kit">
  <main>
    <Hero />

    <!-- How It Works -->
    <section class="how-it-works">
      <img class="falling-key" src="/Photos/FallingKeeb.png" alt="" aria-hidden="true" />
      <div class="how-it-works__inner">
        <h2 class="section-title">HOW IT WORKS</h2>
        <ol class="steps">
          <li class="step">
            <span class="step__number">01</span>
            <div class="step__content">
              <h3 class="step__title">FOLLOW THE GUIDE</h3>
              <p class="step__desc">Read through the docs. Learn about switches, PCBs, keycaps, and how it all fits together.</p>
            </div>
          </li>
          <li class="step">
            <span class="step__number">02</span>
            <div class="step__content">
              <h3 class="step__title">WE SHIP THE PARTS</h3>
              <p class="step__desc">Once you're ready, we send you everything: PCB, switches, keycaps, the whole kit.</p>
            </div>
          </li>
          <li class="step">
            <span class="step__number">03</span>
            <div class="step__content">
              <h3 class="step__title">BUILD YOUR BOARD</h3>
              <p class="step__desc">Solder, assemble, flash your firmware, and you've got a custom mechanical keyboard.</p>
            </div>
          </li>
        </ol>
      </div>
    </section>

    <!-- CTA Banner -->
    <section class="cta-banner bg-grid-dense">
      <div class="cta-banner__inner">
        <h2 class="cta-banner__title">READY TO GET STARTED?</h2>
        <p class="cta-banner__text">Check the docs, join the community, and start your build.</p>
        <div class="cta-banner__buttons">
          <a href="/docs" class="btn btn--primary">READ THE DOCS</a>
          <a href="https://github.com/hackclub/keeb" target="_blank" rel="noopener noreferrer" class="btn btn--outline">VIEW ON GITHUB</a>
        </div>
      </div>
    </section>
  </main>
  <Footer />

  <!-- Easter egg overlay -->
  <div id="easter-egg-overlay" class="egg-overlay" aria-hidden="true">
    <div class="egg-overlay__scanlines"></div>
    <div class="egg-overlay__content">
      <pre class="egg-overlay__ascii">
 ‚Ėą‚Ėą‚ēó  ‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó
 ‚Ėą‚Ėą‚ēĎ ‚Ėą‚Ėą‚ēĒ‚ēĚ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚ēź‚ēĚ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚ēź‚ēĚ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēó
 ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó  ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó  ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ
 ‚Ėą‚Ėą‚ēĒ‚ēź‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēĚ  ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēĚ  ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēó
 ‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ
 ‚ēö‚ēź‚ēĚ  ‚ēö‚ēź‚ēĚ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ
      </pre>
      <p class="egg-overlay__msg">// KEEB UNLOCKED</p>
      <p class="egg-overlay__sub">you typed the magic word. now go build one.</p>
    </div>
  </div>
</BaseLayout>

<script>
  const SEQUENCE = ['K', 'E', 'E', 'B'];
  let buffer: string[] = [];
  let eggActive = false;

  function triggerEasterEgg() {
    if (eggActive) return;
    eggActive = true;

    // 1. Glitch the page
    document.body.classList.add('egg-glitch');

    // 2. Wave-light every key on the keyboard visual
    const keys = document.querySelectorAll('.key');
    const keyboard = document.querySelector('.keyboard-case');
    if (keyboard) {
      const rect = keyboard.getBoundingClientRect();
      const centerX = rect.left + rect.width / 2;
      const centerY = rect.top + rect.height / 2;

      keys.forEach((key) => {
        const kr = key.getBoundingClientRect();
        const kx = kr.left + kr.width / 2;
        const ky = kr.top + kr.height / 2;
        const dist = Math.sqrt((kx - centerX) ** 2 + (ky - centerY) ** 2);
        const delay = dist * 1.8;

        setTimeout(() => {
          key.classList.add('key--wave');
          setTimeout(() => {
            key.classList.remove('key--wave');
            key.classList.add('key--lit');
          }, 400);
        }, delay);
      });
    }

    // 3. Show overlay after keys finish
    setTimeout(() => {
      const overlay = document.getElementById('easter-egg-overlay');
      if (overlay) {
        overlay.classList.add('egg-overlay--active');
      }
    }, 800);

    // 4. Dismiss on click or key
    const dismiss = () => {
      const overlay = document.getElementById('easter-egg-overlay');
      if (overlay) overlay.classList.remove('egg-overlay--active');
      document.body.classList.remove('egg-glitch');
      keys.forEach((key) => key.classList.remove('key--lit', 'key--wave'));
      eggActive = false;
      buffer = [];
      document.removeEventListener('click', dismiss);
      document.removeEventListener('keydown', dismiss);
    };

    setTimeout(() => {
      document.addEventListener('click', dismiss, { once: true });
      document.addEventListener('keydown', dismiss, { once: true });
    }, 1200);
  }

  // Listen for clicks on the CSS keyboard keys
  document.querySelectorAll('.key[data-key]').forEach((keyEl) => {
    keyEl.addEventListener('click', () => {
      if (eggActive) return;
      const label = (keyEl as HTMLElement).dataset.key?.toUpperCase() ?? '';
      if (!label) return;

      // Visual press feedback
      keyEl.classList.add('key--pressed');
      setTimeout(() => keyEl.classList.remove('key--pressed'), 150);

      buffer.push(label);
      if (buffer.length > SEQUENCE.length) buffer.shift();
      if (buffer.length === SEQUENCE.length && buffer.every((k, i) => k === SEQUENCE[i])) {
        triggerEasterEgg();
      }
    });
  });

  // Also keep physical keyboard listener
  document.addEventListener('keydown', (e) => {
    if (eggActive) return;
    const key = e.key.toUpperCase();
    if (key.length === 1 && /[A-Z]/.test(key)) {
      // Highlight the matching visual key
      const visualKey = document.querySelector(`.key[data-key="${key}"]`);
      if (visualKey) {
        visualKey.classList.add('key--pressed');
        setTimeout(() => visualKey.classList.remove('key--pressed'), 150);
      }

      buffer.push(key);
      if (buffer.length > SEQUENCE.length) buffer.shift();
      if (buffer.length === SEQUENCE.length && buffer.every((k, i) => k === SEQUENCE[i])) {
        triggerEasterEgg();
      }
    }
  });
</script>

<style>
  /* --- CTA Banner --- */
  .cta-banner {
    padding: clamp(4rem, 8vh, 7rem) 1.5rem;
  }

  .cta-banner__inner {
    text-align: center;
    max-width: 640px;
    margin: 0 auto;
    padding-top: 3rem;
  }

  .cta-banner__title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    letter-spacing: 0.05em;
    margin-bottom: 1rem;
    display: inline-block;
  }

  .cta-banner__title::after {
    content: '';
    display: block;
    width: 100%;
    height: 3px;
    background: var(--purple-royal);
    margin-top: 0.75rem;
  }

  .cta-banner__text {
    margin-bottom: 2rem;
  }

  .cta-banner__buttons {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  /* --- How It Works --- */
  .how-it-works {
    padding: 4rem 1.5rem;
    background: var(--purple-deep);
    position: relative;
    overflow: hidden;
  }

  .falling-key {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    pointer-events: none;
    opacity: 0.9;
    transform: scale(0.8) translateX(-1cm);
  }

  .how-it-works__inner {
    max-width: 640px;
    margin: 0 auto;
  }

  .section-title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    margin-bottom: 3rem;
    letter-spacing: 0.05em;
  }

  .section-title::after {
    content: '';
    display: block;
    width: 48px;
    height: 3px;
    background: var(--purple-royal);
    margin-top: 0.75rem;
  }

  .steps {
    list-style: none;
    display: flex;
    flex-direction: column;
  }

  .step {
    display: grid;
    grid-template-columns: 4.5rem 1fr;
    gap: 1rem;
    padding: 2rem 0;
  }

  .step + .step {
    border-top: 1px solid oklch(0.47 0.14 300 / 0.2);
  }

  .step__number {
    font-family: var(--font-display);
    font-size: clamp(2rem, 3.5vw, 3rem);
    font-weight: 700;
    color: color-mix(in srgb, var(--purple-royal) 40%, transparent);
    line-height: 1;
    padding-top: 0.1em;
  }

  .step__title {
    font-size: clamp(1.1rem, 2vw, 1.4rem);
    margin-bottom: 0.5rem;
    letter-spacing: 0.06em;
  }

  .step__desc {
    font-size: 0.8rem;
    color: oklch(0.75 0.04 300);
    line-height: 1.7;
    max-width: 45ch;
  }

  @media (max-width: 480px) {
    .step {
      grid-template-columns: 3rem 1fr;
    }

    .falling-key {
      display: none;
    }

    .cta-banner__inner {
      padding-top: 1rem;
    }

    .how-it-works {
      padding: 3rem 1rem;
    }
  }

  /* --- FAQ --- */
  .faq {
    padding: clamp(4rem, 8vh, 7rem) 1.5rem;
  }

  .faq__inner {
    max-width: 640px;
    margin: 0 auto;
  }

  .faq__list {
    display: flex;
    flex-direction: column;
  }

  .faq__item {
    border-top: 1px solid var(--border-color);
  }

  .faq__item:last-child {
    border-bottom: 1px solid var(--border-color);
  }

  .faq__question {
    display: block;
    padding: 1.25rem 0;
    font-family: var(--font-display);
    font-size: clamp(1rem, 1.8vw, 1.25rem);
    font-weight: 600;
    color: var(--white);
    letter-spacing: 0.04em;
    cursor: pointer;
    list-style: none;
    position: relative;
    padding-right: 2rem;
    text-transform: uppercase;
  }

  .faq__question::-webkit-details-marker {
    display: none;
  }

  .faq__question::after {
    content: '+';
    position: absolute;
    right: 0;
    top: 1.25rem;
    font-family: var(--font-mono);
    font-size: 1.1rem;
    color: var(--purple-royal);
    transition: transform 0.2s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .faq__item[open] .faq__question::after {
    transform: rotate(45deg);
  }

  .faq__answer {
    font-size: 0.8rem;
    color: var(--text-muted);
    line-height: 1.7;
    padding-bottom: 1.25rem;
    max-width: none;
  }

  .faq__cta {
    margin-top: clamp(2.5rem, 5vh, 4rem);
    text-align: center;
  }
</style>

<style is:global>
  /* Easter egg ‚ÄĒ must be global since classes are added by JS */
  .egg-glitch {
    animation: page-glitch 0.3s steps(4) 2;
  }

  @keyframes page-glitch {
    0% { transform: translate(0); }
    20% { transform: translate(-3px, 2px); }
    40% { transform: translate(3px, -1px); }
    60% { transform: translate(-1px, -3px); }
    80% { transform: translate(2px, 1px); }
    100% { transform: translate(0); }
  }

  .egg-overlay {
    position: fixed;
    inset: 0;
    z-index: 10000;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.3s;
  }

  .egg-overlay--active {
    opacity: 1;
    pointer-events: auto;
    background: oklch(0.04 0.006 305 / 0.92);
  }

  .egg-overlay__scanlines {
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0, 0, 0, 0.12) 2px,
      rgba(0, 0, 0, 0.12) 4px
    );
    pointer-events: none;
  }

  .egg-overlay__content {
    text-align: center;
    z-index: 1;
    animation: egg-slide-in 0.3s ease-out;
  }

  @keyframes egg-slide-in {
    from { transform: translateY(20px) scale(0.95); opacity: 0; }
    to { transform: translateY(0) scale(1); opacity: 1; }
  }

  .egg-overlay__title {
    font-family: var(--font-display);
    font-size: clamp(5rem, 18vw, 12rem);
    font-weight: 700;
    color: var(--purple-royal);
    letter-spacing: 0.1em;
    line-height: 1;
    margin-bottom: 1.5rem;
  }

  .egg-overlay__sub {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--text-muted);
    letter-spacing: 0.05em;
  }

  @media (max-width: 480px) {
    .egg-overlay__ascii {
      font-size: 0.35rem;
      line-height: 1.2;
    }

    .egg-overlay__content {
      padding: 0 1rem;
    }
  }
</style>
