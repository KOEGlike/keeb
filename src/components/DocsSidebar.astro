---
import { getCollection } from 'astro:content';

const docs = await getCollection('docs');
const sorted = docs.sort((a, b) => a.data.order - b.data.order);
const currentPath = Astro.url.pathname;
---

<aside class="sidebar">
  <div class="sidebar__header">
    <a href="/" class="sidebar__logo">KEEB</a>
    <span class="sidebar__label">DOCS</span>
  </div>
  <nav class="sidebar__nav">
    {sorted.map((doc) => {
      const href = `/docs/${doc.id}`;
      const isActive = currentPath === href || currentPath === `${href}/`;
      return (
        <a
          href={href}
          class:list={['sidebar__link', isActive && 'sidebar__link--active']}
        >
          {doc.data.title}
        </a>
      );
    })}
  </nav>
  <div class="sidebar__footer">
    <a href="https://github.com" target="_blank" rel="noopener noreferrer" class="sidebar__ext-link">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
      </svg>
      GitHub
    </a>
  </div>
</aside>

<style>
  .sidebar {
    width: 260px;
    min-height: 100vh;
    background: var(--bg-card);
    border-right: 2px solid var(--border-color);
    position: fixed;
    top: 0;
    left: 0;
    display: flex;
    flex-direction: column;
    overflow-y: auto;
    z-index: 50;
  }

  .sidebar__header {
    padding: 1.25rem 1.5rem;
    border-bottom: 2px solid var(--border-color);
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
  }

  .sidebar__logo {
    font-family: var(--font-display);
    font-size: 1.5rem;
    color: var(--white);
    text-decoration: none;
    letter-spacing: 0.12em;
  }

  .sidebar__logo:hover {
    color: var(--purple-royal);
  }

  .sidebar__label {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--text-muted);
    letter-spacing: 0.2em;
    border: 1px solid var(--border-color);
    padding: 0.15rem 0.4rem;
  }

  .sidebar__nav {
    flex: 1;
    padding: 1rem 0;
    display: flex;
    flex-direction: column;
  }

  .sidebar__link {
    display: block;
    padding: 0.6rem 1.5rem;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-muted);
    text-decoration: none;
    border-left: 3px solid transparent;
    transition: color 0.1s, border-color 0.1s, background 0.1s;
  }

  .sidebar__link:hover {
    color: var(--white);
    background: rgba(120, 81, 169, 0.08);
  }

  .sidebar__link--active {
    color: var(--white);
    border-left-color: var(--purple-royal);
    background: rgba(120, 81, 169, 0.1);
  }

  .sidebar__footer {
    padding: 1rem 1.5rem;
    border-top: 1px solid var(--border-color);
  }

  .sidebar__ext-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.75rem;
    color: var(--text-muted);
    text-decoration: none;
  }

  .sidebar__ext-link:hover {
    color: var(--purple-royal);
  }

  @media (max-width: 768px) {
    .sidebar {
      display: none;
    }
  }
</style>
