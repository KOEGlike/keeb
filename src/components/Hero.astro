---
import Button from './Button.astro';
import KeyboardVisual from './KeyboardVisual.astro';
---

<section class="hero bg-grid">

  <div class="hero__photos hero__photos--left" aria-hidden="true">
    <img class="photo" src="/Photos/KB1.png" alt="" style="--r: -6deg; --y: 2%" />
    <img class="photo" src="/Photos/KB3.png" alt="" style="--r: 4deg;  --y: 26%" />
    <img class="photo" src="/Photos/KB5.png" alt="" style="--r: -8deg; --y: 50%" />
    <img class="photo" src="/Photos/KB7.png" alt="" style="--r: 5deg;  --y: 74%" />
  </div>

  <div class="hero__photos hero__photos--right" aria-hidden="true">
    <img class="photo" src="/Photos/KB2.png" alt="" style="--r: 7deg;  --y: 2%" />
    <img class="photo" src="/Photos/KB4.png" alt="" style="--r: -5deg; --y: 26%" />
    <img class="photo" src="/Photos/KB6.png" alt="" style="--r: 6deg;  --y: 50%" />
    <img class="photo" src="/Photos/KB8.png" alt="" style="--r: -4deg; --y: 74%" />
  </div>

  <div class="hero__content">
    <h1 class="hero__title">
      BUILD YOUR<br />OWN <span class="hero__accent">KEYBOARD</span>
    </h1>
    <p class="hero__sub">
      A Hack Club you-ship-we-ship project.<br />
      Follow the guide. We ship the parts. You build it.
    </p>
    <div class="hero__cta">
      <Button href="/docs" variant="primary">START BUILDING</Button>
      <Button href="https://github.com/hackclub/keeb" variant="outline" external>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
        </svg>
        VIEW SOURCE
      </Button>
    </div>
  </div>
  <div class="hero__keyboard">
    <KeyboardVisual />
  </div>

  <div class="hero__strip">
    <img src="/Photos/Group 1.png" alt="Keyboard builds" />
  </div>
</section>

<style>
  @keyframes enter {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .hero {
    height: 100svh;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: clamp(5rem, 12vh, 10rem) 1.5rem 0;
    position: relative;
    overflow: hidden;
  }

  .hero__content {
    text-align: center;
    position: relative;
    z-index: 1;
    max-width: 800px;
  }

  .hero__title {
    font-size: clamp(2.5rem, 8vw, 6rem);
    line-height: 0.95;
    margin-bottom: 1.5rem;
    letter-spacing: 0.02em;
    animation: enter 0.6s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  .hero__accent {
    color: var(--purple-royal);
    position: relative;
    font-family: 'KeyNormal', var(--font-display);
  }

  .hero__accent::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: 0.05em;
    width: 100%;
    height: 4px;
    background: var(--purple-deep);
  }

  .hero__sub {
    font-size: clamp(0.8rem, 1.4vw, 1rem);
    color: var(--text-muted);
    margin-bottom: 2.5rem;
    line-height: 1.8;
    max-width: 500px;
    margin-left: auto;
    margin-right: auto;
    animation: enter 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.1s both;
  }

  .hero__cta {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    animation: enter 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.2s both;
  }

  .hero__keyboard {
    margin-top: clamp(1.5rem, 4vh, 3rem);
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 750px;
    flex-shrink: 0;
    animation: enter 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.35s both;
  }

  .hero__photos {
    position: absolute;
    top: 5rem;
    bottom: 0;
    width: 220px;
    pointer-events: none;
    z-index: 0;
  }

  .hero__photos--left { left: 0; }
  .hero__photos--right { right: 0; }

  .photo {
    position: absolute;
    width: 180px;
    aspect-ratio: 4/3;
    object-fit: cover;
    top: var(--y);
    rotate: var(--r);
    border: 6px solid var(--white);
    box-shadow: 4px 4px 0 var(--purple-deep);
    display: block;
  }

  .hero__photos--left .photo { right: 0.5rem; }
  .hero__photos--right .photo { left: 0.5rem; }

  .hero__strip {
    position: absolute;
    bottom: 1in;
    left: 220px;
    right: 220px;
    line-height: 0;
    z-index: 0;
  }

  .hero__strip img {
    width: 85%;
    height: auto;
    display: block;
    margin: 0 auto;
  }

  @media (max-width: 1100px) {
    .hero__photos { display: none; }
  }

  @media (max-width: 768px) {
    .hero {
      padding: clamp(3rem, 8vh, 5rem) 1rem 0;
    }

    .hero__sub {
      font-size: 0.85rem;
    }
  }
</style>
