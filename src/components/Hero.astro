---
import Button from './Button.astro';
import KeyboardVisual from './KeyboardVisual.astro';
---

<section class="hero bg-grid">
  <div class="hero__content">
    <h1 class="hero__title">
      BUILD YOUR<br />OWN <span class="hero__accent">KEYBOARD</span>
    </h1>
    <p class="hero__sub">
      A Hack Club you-ship-we-ship project.<br />
      Follow the guide. We ship the parts. You build it.
    </p>
    <div class="hero__cta">
      <Button href="/docs" variant="primary">START BUILDING</Button>
      <Button href="https://github.com/hackclub/keeb" variant="outline" external>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
        </svg>
        VIEW SOURCE
      </Button>
    </div>
  </div>
  <div class="hero__keyboard">
    <KeyboardVisual />
  </div>
  <div class="hero__scroll-hint">
    <span>SCROLL</span>
    <div class="hero__scroll-line"></div>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 6rem 1.5rem 3rem;
    position: relative;
    overflow: hidden;
  }

  /* Crosshatch texture in corner */
  .hero::before {
    content: '';
    position: absolute;
    top: 0;
    right: 0;
    width: 400px;
    height: 400px;
    background-image:
      repeating-linear-gradient(
        45deg,
        transparent,
        transparent 6px,
        rgba(75, 0, 110, 0.12) 6px,
        rgba(75, 0, 110, 0.12) 7px
      );
    pointer-events: none;
  }

  /* Bottom-left crosshatch */
  .hero::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 350px;
    height: 350px;
    background-image:
      repeating-linear-gradient(
        -45deg,
        transparent,
        transparent 6px,
        rgba(120, 81, 169, 0.1) 6px,
        rgba(120, 81, 169, 0.1) 7px
      );
    pointer-events: none;
  }

  .hero__content {
    text-align: center;
    position: relative;
    z-index: 1;
    max-width: 800px;
  }

  .hero__title {
    font-size: clamp(3rem, 10vw, 8rem);
    line-height: 0.95;
    margin-bottom: 1.5rem;
    letter-spacing: 0.04em;
  }

  .hero__accent {
    color: var(--purple-royal);
    position: relative;
  }

  .hero__accent::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: 0.05em;
    width: 100%;
    height: 4px;
    background: var(--purple-deep);
  }

  .hero__sub {
    font-size: clamp(0.85rem, 1.5vw, 1.05rem);
    color: var(--text-muted);
    margin-bottom: 2.5rem;
    line-height: 1.8;
    max-width: 500px;
    margin-left: auto;
    margin-right: auto;
  }

  .hero__cta {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .hero__keyboard {
    margin-top: 3rem;
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 750px;
  }

  .hero__scroll-hint {
    position: absolute;
    bottom: 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    color: var(--text-muted);
    font-size: 0.65rem;
    letter-spacing: 0.3em;
    z-index: 1;
  }

  .hero__scroll-line {
    width: 1px;
    height: 40px;
    background: var(--purple-deep);
    animation: scroll-pulse 2s ease-in-out infinite;
  }

  @keyframes scroll-pulse {
    0%, 100% { opacity: 0.3; transform: scaleY(0.6); }
    50% { opacity: 1; transform: scaleY(1); }
  }

  @media (max-width: 768px) {
    .hero {
      padding: 5rem 1rem 2rem;
      min-height: auto;
    }

    .hero__sub {
      font-size: 0.85rem;
    }

    .hero__scroll-hint {
      display: none;
    }
  }
</style>
