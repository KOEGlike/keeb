---
import Button from './Button.astro';
import KeyboardVisual from './KeyboardVisual.astro';
---

<section class="hero bg-grid">
  <div class="hero__content">
    <h1 class="hero__title">
      BUILD YOUR<br />OWN <span class="hero__accent">KEYBOARD</span>
    </h1>
    <p class="hero__sub">
      A Hack Club you-ship-we-ship project.<br />
      Follow the guide. We ship the parts. You build it.
    </p>
    <div class="hero__cta">
      <Button href="/docs" variant="primary">GET STARTED</Button>
    </div>
  </div>
  <div class="hero__keyboard">
    <KeyboardVisual />
  </div>
</section>

<style>
  @keyframes enter {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .hero {
    height: 100svh;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: clamp(5rem, 12vh, 10rem) 1.5rem 0;
    position: relative;
    overflow: hidden;
  }

  .hero__content {
    text-align: center;
    position: relative;
    z-index: 1;
    max-width: 800px;
  }

  .hero__title {
    font-size: clamp(2.5rem, 8vw, 6rem);
    line-height: 0.95;
    margin-bottom: 1.5rem;
    letter-spacing: 0.02em;
    animation: enter 0.6s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  .hero__accent {
    color: var(--purple-royal);
    position: relative;
  }

  .hero__accent::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: 0.05em;
    width: 100%;
    height: 4px;
    background: var(--purple-deep);
  }

  .hero__sub {
    font-size: clamp(0.8rem, 1.4vw, 1rem);
    color: var(--text-muted);
    margin-bottom: 2.5rem;
    line-height: 1.8;
    max-width: 500px;
    margin-left: auto;
    margin-right: auto;
    animation: enter 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.1s both;
  }

  .hero__cta {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    animation: enter 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.2s both;
  }

  .hero__keyboard {
    margin-top: clamp(1.5rem, 4vh, 3rem);
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 750px;
    flex-shrink: 0;
    animation: enter 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.35s both;
  }

  @media (max-width: 768px) {
    .hero {
      padding: clamp(3rem, 8vh, 5rem) 1rem 0;
    }

    .hero__sub {
      font-size: 0.85rem;
    }
  }
</style>
