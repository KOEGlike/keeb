---
import Button from './Button.astro';
---

<a href="/" class="nav__flag">
  <img src="https://assets.hackclub.com/flag-orpheus-top.svg" alt="Hack Club" />
</a>
<nav class="nav">
  <div class="nav__inner">
    <a href="/" class="nav__logo">KEEB</a>
    <div class="nav__links">
      <Button href="/docs" variant="outline">DOCS</Button>
    </div>
  </div>
</nav>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(10, 10, 10, 0.92);
    border-bottom: 2px solid var(--purple-deep);
    backdrop-filter: blur(8px);
  }

  .nav__flag {
    position: fixed;
    top: 0;
    left: 1rem;
    z-index: 999;
    display: block;
    line-height: 0;
  }

  .nav__flag img {
    width: 6rem;
    display: block;
  }

  @media (max-width: 1200px) {
    .nav__flag {
      display: none;
    }
  }

  .nav__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0.75rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav__logo {
    font-family: var(--font-display);
    font-size: 2rem;
    color: var(--white);
    letter-spacing: 0.15em;
    text-decoration: none;
  }

  .nav__logo:hover {
    color: var(--purple-royal);
  }

  .nav__links {
    display: flex;
    gap: 0.75rem;
    align-items: center;
  }

  @media (max-width: 480px) {
    .nav__inner {
      padding: 0.5rem 0.75rem 0.5rem 4rem;
    }

    .nav__logo {
      font-size: 1.5rem;
    }

    .nav__links {
      gap: 0.5rem;
    }

    .nav__links :global(.btn) {
      padding: 0.5rem 0.75rem;
      font-size: 0.8rem;
    }
  }
</style>
