---
import Button from './Button.astro';
---

<a href="/" class="nav__flag">
  <img src="https://assets.hackclub.com/flag-orpheus-top.svg" alt="Hack Club" />
</a>
<nav class="nav">
  <div class="nav__inner">
    <a href="/" class="nav__logo">KEEB</a>
    <div class="nav__links">
      <Button href="/docs" variant="outline">DOCS</Button>
      <Button href="https://github.com/hackclub/keeb" variant="primary" external>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
        </svg>
        GITHUB
      </Button>
    </div>
  </div>
</nav>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(10, 10, 10, 0.92);
    border-bottom: 2px solid var(--purple-deep);
    backdrop-filter: blur(8px);
  }

  .nav__flag {
    position: fixed;
    top: 0;
    left: 1rem;
    z-index: 999;
    display: block;
    line-height: 0;
  }

  .nav__flag img {
    width: 6rem;
    display: block;
  }

  @media (max-width: 480px) {
    .nav__flag img {
      width: 4.5rem;
    }
    .nav__flag {
      left: 0.5rem;
    }
  }

  .nav__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0.75rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav__logo {
    font-family: var(--font-display);
    font-size: 2rem;
    color: var(--white);
    letter-spacing: 0.15em;
    text-decoration: none;
  }

  .nav__logo:hover {
    color: var(--purple-royal);
  }

  .nav__links {
    display: flex;
    gap: 0.75rem;
    align-items: center;
  }

  @media (max-width: 480px) {
    .nav__inner {
      padding: 0.5rem 0.75rem 0.5rem 4rem;
    }

    .nav__logo {
      font-size: 1.5rem;
    }

    .nav__links {
      gap: 0.5rem;
    }

    .nav__links :global(.btn) {
      padding: 0.5rem 0.75rem;
      font-size: 0.8rem;
    }
  }
</style>
